# Copy to .env.oss or export these variables before uploading to OSS.
#
# Local LAN installation does not need OSS.
#
# Usage:
#   cp oss.env.example .env.oss
#   edit .env.oss
#   ./serve-ios-ota.command --upload-oss

OSS_BUCKET=your-bucket-name
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com

# Optional. Defaults to:
# ios-ota/<bundle_id>/<version>-<build>
# OSS_PREFIX=ios-ota/my-app

# Optional. Use this if the public download domain is a CDN/custom domain.
# OSS_PUBLIC_BASE_URL=https://cdn.example.com

ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret

# Optional for STS credentials.
# ALIYUN_OSS_SECURITY_TOKEN=your-security-token

# Optional. Only set this if your bucket policy needs object-level public ACL.
# OSS_ACL=public-read
